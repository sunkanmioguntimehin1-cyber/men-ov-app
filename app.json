{
  "expo": {
    "name": "Menovia",
    "slug": "menovia",
    "owner": "menovia",
    "version": "1.0.13",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "menoviaapp",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "userInterfaceStyle": "light",
        "NSCameraUsageDescription": "This app uses the camera to allow users upload photos. For example, for profile picture and for video recording.",
        "NSMicrophoneUsageDescription": "This app uses the microphone for video recording. For example, when you want to record a video with sound.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library so you can upload photos. For example, for profile picture and for video recording.",
        "FirebaseAutomaticScreenReportingEnabled": false
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.menovia.menovia"
    },
    "android": {
      "userInterfaceStyle": "light",
      "googleServicesFile": "./google-services2.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.menovia.menovia",
      "splash": {
        "dark": {
          "image": "./assets/images/splash-icon.png",
          "backgroundColor": "#171717"
        }
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "menoviaapp"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-notification-service-extension-plugin",
        {
          "mode": "production",
          "iosNSEFilePath": "./assets/NotificationService.m",
          "filtering": false
        }
      ],
      "expo-router",
      "@react-native-firebase/app",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#171717",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#171717"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.903613683909-6pttesaais3m7qdg33r3epiu0dqm4j8o"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification_icon.png",
          "color": "#ffffff",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false,
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "podfileProperties": {
              "use_modular_headers!": true
            },
            "buildReactNativeFromSource": true
          }
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-web-browser",
      "expo-image",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "99d071a9-b0d9-4db0-85b7-90a308101011"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/99d071a9-b0d9-4db0-85b7-90a308101011"
    }
  }
}
